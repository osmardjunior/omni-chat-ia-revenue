# -----------------------------------------------------------------------------
# CONFIGURAÇÕES DE AMBIENTE - OPERAÇÃO COMERCIAL CONVERSACIONAL COM IA
# Copie este arquivo para um arquivo nomeado ".env" na raiz do projeto e preencha as chaves.
# -----------------------------------------------------------------------------

# 1. INTEGRAÇÕES DE INTELIGÊNCIA ARTIFICIAL (GEMINI)
# Usado para analisar os dados extraídos do site do lead e gerar diagnósticos hiper-personalizados.
GEMINI_API_KEY=sua_chave_da_api_do_gemini_aqui

# 2. RASTREAMENTO E RASPAGEM DE SITES (FIRECRAWL)
# Usado para extrair o conteúdo do site/e-commerce do lead, identificando canais de atendimento instalados,
# fluxos de cabeçalho, pop-ups de WhatsApp ou chat ativo para calibrar a dor do cliente.
FIRECRAWL_API_KEY=sua_chave_da_api_do_firecrawl_aqui

# 3. CONFIGURAÇÕES PÚBLICAS DO FRONT-END (Astro requer prefixo PUBLIC_)
# O número do WhatsApp corporativo (com DDI e DDD, apenas números) que receberá as mensagens com os diagnósticos concluídos.
PUBLIC_COMPANY_WHATSAPP=5511999999999

# URL base da aplicação para redirecionamentos e mapeamento de links de retorno nas mensagens.
PUBLIC_APP_URL=http://localhost:4321

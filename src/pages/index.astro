---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import StageLanding from '../components/StageLanding.astro';
import StageQuiz from '../components/StageQuiz.astro';
import StageResults from '../components/StageResults.astro';
import StageLead from '../components/StageLead.astro';
import FaultyTerminal from '../components/ui/FaultyTerminal.astro';
---

<Layout title="Diagnóstico de IA Comercial • OmniChat">
  <!-- Persistent Animated WebGL Background Backdrop -->
  <div class="fixed inset-0 z-0 overflow-hidden pointer-events-none">
    <FaultyTerminal
      class="opacity-90"
      scale={1.5}
      digitSize={1.2}
      scanlineIntensity={0.5}
      glitchAmount={1}
      flickerAmount={1}
      noiseAmp={1}
      chromaticAberration={0}
      dither={0}
      curvature={0.1}
      tint="#7C3AED"
      mouseReact
      mouseStrength={0.5}
      brightness={0.6}
    />
    <div
      class="pointer-events-none absolute inset-0"
      style="background: radial-gradient(120% 90% at 18% 42%, rgba(9,7,14,0.92) 0%, rgba(9,7,14,0.82) 38%, rgba(9,7,14,0.55) 72%, rgba(9,7,14,0.35) 100%);"
    ></div>
  </div>

  <main class="min-h-screen relative z-10 bg-transparent text-foreground transition-colors duration-300">
    <Header />

    <div class="mx-auto max-w-6xl px-4 py-12 md:py-20">
      <StageQuiz />
      <StageResults />
      <StageLead />
    </div>
  </main>

  <!-- Full-screen landing overlay (Figma design) -->
  <StageLanding />
</Layout>

<script>

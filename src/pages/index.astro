      image: "https://images.unsplash.com/photo-1559839734-2b71ea197ec2?q=80&w=600&auto=format&fit=crop",
      metrics: [
        { badge: "90%", label: "De redução no tempo de resposta inicial" },
        { badge: "24/7", label: "Atendimento e triagem automática de pacientes" },
        { badge: "10x", label: "Mais agilidade no handoff para consultores" }
      ]
    },
    'Serviços Financeiros': {
      image: "https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?q=80&w=600&auto=format&fit=crop",
      metrics: [
        { badge: "60%", label: "De redução no tempo de atendimento humano" },

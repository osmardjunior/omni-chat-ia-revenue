  } as const;

  // Premium Case Study Assets (Image + Metric Badges matching the premium tela-04-final redesign)
  const PREMIUM_CASE_ASSETS = {
    'Varejo & E-commerce': {
      image: "https://images.unsplash.com/photo-1534528741775-53994a69daeb?q=80&w=600&auto=format&fit=crop",
      metrics: [
        { badge: "25%", label: "De recuperação dos carrinhos abandonados" },

---
import Button from './ui/Button.astro';
import FaultyTerminal from './ui/FaultyTerminal.astro';
import logoOmnichat from '../image/logo-omnichat.svg';
---
<!-- ==================== TELA 1: LANDING / HERO (full-screen) ==================== -->
<section
  id="stage-1"
  class="fixed inset-0 z-50 overflow-hidden bg-transparent text-foreground"
>

  <!-- Content -->
  <div class="relative z-10 mx-auto flex h-full max-w-[1240px] flex-col px-6 py-7 md:px-14 md:py-9">
    <!-- Top bar: logo + tagline -->
    <header class="flex items-center justify-between">
      <a href="/" class="flex items-center gap-2.5">
        <img
          src={logoOmnichat.src}
          alt="OmniChat Logo"
          class="md:h-11 w-auto h-12"
          loading="eager"
        />
      </a>
      <p class="hidden text-sm font-medium tracking-wide sm:block xl:justify-between xl:items-stretch text-[#ffffff]">
        Mapeamento de Maturidade <span class="mx-1 text-accent/70">&bull;</span> Revenue AI
      </p>
    </header>

    <!-- Hero -->
    <div class="flex flex-1 flex-col justify-center">
      <div class="max-w-[1000px]">
        <h1 
          class="font-lato leading-[1.05] tracking-[-0.015em] text-[#FFD04D]"
          style="font-size: clamp(2.4rem, 6.2vw, 5rem); line-height: clamp(2.6rem, 6.2vw, 5rem); font-weight: 275;"
        >
          Sua operação está pronta para transformar IA em canal de receita?
        </h1>

        <p class="mt-8 font-medium md:text-base font-lato text-[#fbfaff] text-4xl max-w-[100%]">
          Avalie em menos de 3 minutos a maturidade da sua empresa em canais de venda
          com IA, atribuição, autonomia operacional e governança comercial no WhatsApp.
        </p>
      </div>
    </div>

    <!-- Bottom-right CTA -->
    <div class="flex items-end justify-end">
      <div class="flex flex-col items-end gap-3">
        <Button
          id="btn-start-simulation"
          variant="outline"
          class="group !rounded-xl !border-accent/60 px-8 py-4 text-sm font-bold uppercase tracking-[0.08em] !text-accent hover:!border-accent hover:!bg-accent/10"
        >
          Iniciar Diagnóstico Gratuito
          <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </Button>
        <p class="text-xs text-muted/80">Resultado imediato &bull; Sem custo</p>
      </div>
    </div>
  </div>
</section>

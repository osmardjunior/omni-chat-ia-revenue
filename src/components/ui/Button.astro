---
interface Props {
  id?: string;
  class?: string;
  type?: 'button' | 'submit' | 'reset';
  variant?: 'primary' | 'outline' | 'success' | 'link';
  href?: string;
  target?: string;
}

const { id, class: className = '', type = 'button', variant = 'primary', href, target } = Astro.props;

const baseStyles = "inline-flex items-center justify-center gap-2 font-display font-semibold rounded-xl transition-all duration-200 cursor-pointer";
const variants = {
  primary: "bg-accent text-background shadow-lg shadow-accent/25 hover:shadow-xl hover:shadow-accent/35 hover:-translate-y-0.5 active:translate-y-0",
  outline: "border border-foreground/10 hover:border-foreground/20 hover:bg-foreground/5 text-foreground",
  success: "bg-emerald-600 hover:bg-emerald-500 text-white shadow-lg hover:scale-[1.01] active:scale-100",
  link: "text-xs text-muted hover:text-foreground transition-colors"
};

const finalClass = `${baseStyles} ${variants[variant]} ${className}`;
---

{
  href ? (
    <a id={id} href={href} target={target} class={finalClass}>
      <slot />
    </a>
  ) : (
    <button id={id} type={type} class={finalClass}>
      <slot />
    </button>
  )
}

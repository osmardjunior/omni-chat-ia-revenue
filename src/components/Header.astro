---
import logoOmnichat from '../image/logo-omnichat.svg';
---
<!-- Global Header/Navbar (shown on Results/Lead stages; matches Figma big logo + tagline + blue divider) -->
<header id="global-header" class="hidden border-b-2 border-[#4F84F5] py-5 px-6 md:px-14 bg-transparent relative z-20">
  <div class="mx-auto max-w-[1240px] flex items-center justify-between">
    <a href="/" class="flex items-center gap-2.5">
      <img
        src={logoOmnichat.src}
        alt="OmniChat Logo"
        class="h-9 md:h-11 w-auto"
        loading="eager"
      />
    </a>
    <p class="hidden sm:block text-sm font-medium tracking-wide text-muted font-lato">
      Mapeamento de Maturidade <span class="mx-1 text-accent/70">&bull;</span> Revenue AI
    </p>
  </div>
</header>

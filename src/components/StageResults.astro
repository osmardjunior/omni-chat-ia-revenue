---
import Button from './ui/Button.astro';

const dimensions = [
  {
    id: 'revenue',
    name: '1. Estratégia e Canal',
    description: 'Papel da IA no funil comercial e metas de receita explícitas.'
  },
  {
    id: 'data',
    name: '2. Dados e Atribuição',
    description: 'Rastreabilidade de mídias pagas (Meta Ads) e dashboards de receita.'
  },
  {
    id: 'autonomy',
    name: '3. Operação e Performance',
    description: 'Tempo de resposta imediato, FAQs dinâmicos e objeções fluidas.'
  },
  {
    id: 'human',
    name: '4. Governança e Segurança',
    description: 'Travas rígidas de preços/descontos e handoffs estruturados de IA-humano.'
  },
  {
    id: 'governance',
    name: '5. Ownership e Organização',
    description: 'Líder dedicado do canal conversacional e cadência semanal de testes e dados.'
  }
] as const;
---

<!-- ==================== TELA 3: RESULTADOS (Figma Accordion Edit) ==================== -->
<section id="stage-3" class="hidden space-y-10 transition-all duration-500 ease-in-out animate-fade-in relative z-10">
  
  <!-- Title Header (Thin Typographic Look matching Figma) -->
  <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 max-w-[1240px]">
    <div class="space-y-4 max-w-2xl">
      <h1 class="font-lato leading-[1.1] tracking-[-0.01em] text-[#FFD04D]" style="font-size: clamp(2.5rem, 5.5vw, 4.2rem); font-weight: 275;">
        Diagnóstico de <br />
        Maturidade de IA Comercial
      </h1>
      <p class="text-zinc-400 text-sm md:text-base font-lato font-light leading-relaxed">
        Relatório estruturado de prontidão para habilitar agentes inteligentes como canal de vendas ativo de alta performance no WhatsApp.
      </p>
    </div>
    
    <div class="shrink-0 space-y-1">
      <label for="select-sector" class="text-[9px] font-extrabold uppercase tracking-widest text-zinc-400 block font-lato">Setor de Atuação</label>
      <select 
        id="select-sector" 
        class="px-3.5 py-2.5 rounded-xl border border-white/10 bg-[#110f17]/80 text-[#FFD04D] focus:border-purple-500 focus:ring-1 focus:ring-purple-500 outline-none text-xs font-bold cursor-pointer font-lato transition-all"
      >
        <option value="Varejo & E-commerce" selected>Varejo & E-commerce</option>
        <option value="Saúde & Clínicas">Saúde & Clínicas</option>
        <option value="Serviços Financeiros">Serviços Financeiros</option>
        <option value="Tecnologia & SaaS">Tecnologia & SaaS</option>
        <option value="Logística & Distribuição">Logística & Distribuição</option>
        <option value="Outros">Outros</option>
      </select>
    </div>
  </div>

  <!-- Typographic Score Dashboard (Large 57% & Split Stage Name matching Figma) -->
  <div class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-12 items-start py-6 border-b border-[#FFD04D]/15">
    <!-- Left Column: Big Typographic Score -->
    <div class="md:col-span-5 flex flex-col justify-start">
      <div class="font-lato font-black text-[7.5rem] md:text-[9.5rem] leading-[0.95] text-white tracking-tighter" id="res-overall-score">
        57%
      </div>
      <div class="space-y-1 text-[10px] md:text-[11px] font-bold uppercase tracking-[0.18em] text-zinc-400 font-lato mt-4">
        <div id="res-market-average-label">MÉDIA DO MERCADO 63%</div>
        <div>MATURIDADE GERAL</div>
        <div class="text-[#FFD04D]" id="res-maturity-stage-label">EM ESTRUTURAÇÃO</div>
      </div>
    </div>

    <!-- Right Column: Maturity Description -->
    <div class="md:col-span-7 space-y-5 md:pt-4">
      <div class="space-y-1">
        <span class="text-lg md:text-xl font-light text-[#FFD04D] font-lato tracking-wide block" id="res-maturity-stage-number">Estágio 3</span>
        <h2 class="font-lato font-bold text-[2.5rem] md:text-[3.75rem] leading-[1.05] text-[#FFD04D] figma-stage-name" id="res-maturity-stage-name">
          Canal em Estruturação
        </h2>
      </div>
      <div class="figma-stage-desc w-full space-y-4 md:text-base font-lato font-light text-2xl text-left text-[#fbfbfc]">
        <p id="res-maturity-stage-desc-1">
          Você já possui fluxos e integrações básicas direcionadas à qualificação ou prospecção de leads.
        </p>
        <p id="res-maturity-stage-desc-2" class="text-[#ffffff]">
          No entanto, ainda enfrenta gargalos em atribuição de Meta Ads de ponta a ponta e governança comercial para transações seguras.
        </p>
      </div>
    </div>
  </div>

  <!-- Informational subtitle -->
  <div class="py-4">
    <p class="text-[9px] md:text-[10px] font-bold uppercase tracking-[0.2em] text-zinc-400 font-lato leading-relaxed max-w-4xl">
      ABAIXO ESTÃO AS PONTUAÇÕES INDIVIDUAIS PARA CADA UM DOS PILARES DE PRONTIDÃO COMERCIAL, COM OS PONTOS DE MAIOR URGÊNCIA DESTACADOS.
    </p>
  </div>

  <!-- COLUMN HEADERS (Pill Labels matching Figma) -->
  <div class="hidden md:grid md:grid-cols-[4rem_1fr_1fr_1fr] gap-6 items-center px-6 mb-2">
    <!-- Number space -->
    <div class="w-12"></div>
    
    <!-- Header 1 -->
    <div class="text-center py-2 px-4 rounded-full border border-white/10 bg-[#0c0a10]/80 text-[9px] font-black uppercase tracking-wider text-zinc-300 font-lato shadow-sm">
      PRINCIPAIS GARGALOS ESTRATÉGICOS
    </div>
    
    <!-- Header 2 -->
    <div class="text-center py-2 px-4 rounded-full border border-white/10 bg-[#0c0a10]/80 text-[9px] font-black uppercase tracking-wider text-zinc-300 font-lato shadow-sm">
      SCORES & DIMENSÕES DE REVENUE AI
    </div>
    
    <!-- Header 3 -->
    <div class="text-center py-2 px-4 rounded-full bg-[#FFD04D] text-[9px] font-black uppercase tracking-wider text-black font-lato shadow-sm">
      EFICIÊNCIA PROJETADA COM OMNICHAT
    </div>
  </div>

  <!-- THE ACCORDION SYSTEM (All 5 Rows Fully Unlocked and Interactive) -->
  <div class="space-y-5 md:space-y-6">
    {dimensions.map((dim, index) => {
      const numStr = (index + 1) < 10 ? `0${index + 1}` : `${index + 1}`;
      const isActive = index === 0 ? "active" : ""; // First item open by default
      const contentClass = index === 0 ? "" : "hidden";
      const iconText = index === 0 ? "-" : "+";
      const iconClass = index === 0 ? "bg-white text-black font-bold text-xl" : "bg-[#FFD04D] text-black font-bold text-lg";
      
      return (
        <div 
          class={`accordion-item border border-white/[0.06] rounded-[2rem] bg-[#110f17]/40 backdrop-blur-xl transition-all duration-300 ${isActive}`} 
          data-index={index + 1}
        >
          <!-- Accordion trigger -->
          <button class="accordion-trigger w-full flex items-center justify-between p-6 md:p-8 outline-none text-left select-none cursor-pointer">
            <div class="flex items-center gap-4 md:gap-6">
              <span class="font-lato font-extrabold text-xl md:text-2xl text-zinc-500">{numStr}.</span>
              <div class="space-y-0.5">
                <h4 class="font-lato font-extrabold text-lg md:text-xl text-white">{dim.name.replace(/^\d+\.\s*/, '')}</h4>
                <p class="text-xs text-zinc-400 font-lato hidden sm:block">{dim.description}</p>
              </div>
            </div>
            <div class="flex items-center gap-4">
              <span class="font-mono font-extrabold text-base md:text-lg text-[#FFD04D] mr-2" id={`res-dim${index + 1}-score-collapsed`} style={index === 0 ? "display: none;" : "display: inline;"}>0%</span>
              <div class={`accordion-icon h-10 w-10 shrink-0 rounded-full flex items-center justify-center shadow-md transition-all ${iconClass}`}>
                {iconText}
              </div>
            </div>
          </button>
          
          <!-- Accordion Content -->
          <div class={`accordion-content border-t border-white/[0.04] p-6 md:p-8 pt-0 ${contentClass}`}>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 pt-6">
              
              <!-- Card 1: Gargalo -->
              <div 
                id={`res-dim${index + 1}-card1`}
                class={`bg-white rounded-3xl shadow-xl border border-zinc-100 flex flex-col justify-start text-black transition-all duration-300 ${index === 0 ? "p-6 min-h-[180px]" : "p-5 min-h-[70px]"}`}
              >
                <div class="space-y-3">
                  <span class={`text-[9px] font-black uppercase tracking-wider text-zinc-400 block font-lato card-label ${index === 0 ? "" : "hidden"}`}>
                    PRINCIPAIS GARGALOS ESTRATÉGICOS
                  </span>
                  <h4 class="font-lato font-black text-lg text-zinc-900">{dim.name.replace(/^\d+\.\s*/, '')}</h4>
                  <p 
                    id={`res-dim${index + 1}-bottleneck`}
                    class={`text-xs text-zinc-700 leading-relaxed font-medium card-paragraph ${index === 0 ? "" : "hidden"}`}
                  >
                    Carregando...
                  </p>
                </div>
              </div>

              <!-- Card 2: Score -->
              <div 
                id={`res-dim${index + 1}-card2`}
                class={`rounded-3xl shadow-xl flex flex-col justify-between text-black transition-all duration-300 ${index === 0 ? "bg-[#9df09e] p-6 min-h-[180px]" : "bg-[#fffde6] p-5 min-h-[70px]"}`}
              >
                <div class="space-y-1.5">
                  <span class={`text-[9px] font-black uppercase tracking-wider text-zinc-600 block font-lato card-label ${index === 0 ? "" : "hidden"}`}>
                    SCORES & DIMENSÕES DE REVENUE AI
                  </span>
                  <p class="text-[11px] leading-snug font-lato font-semibold text-zinc-800">{dim.description}</p>
                </div>
                
                <div 
                  id={`res-dim${index + 1}-score-block`}
                  class={`space-y-1 mt-4 card-score-block ${index === 0 ? "" : "hidden"}`}
                >
                  <div class="font-lato font-black text-5xl leading-none" id={`res-dim${index + 1}-score-big`}>0%</div>
                  <div 
                    id={`res-dim${index + 1}-badge`}
                    class="text-[8px] font-black uppercase tracking-widest bg-black text-white px-2.5 py-1.5 rounded-full inline-block text-center mt-2.5"
                  >
                    SCORE POSITIVO ACIMA DA MÉDIA
                  </div>
                </div>
              </div>

              <!-- Card 3: Eficiência -->
              <div 
                id={`res-dim${index + 1}-card3`}
                class={`bg-[#FFD04D] rounded-3xl shadow-xl flex flex-col justify-start text-black transition-all duration-300 ${index === 0 ? "p-6 min-h-[180px]" : "p-5 min-h-[70px]"}`}
              >
                <div class="space-y-3">
                  <span class={`text-[9px] font-black uppercase tracking-wider text-zinc-600 block font-lato card-label ${index === 0 ? "" : "hidden"}`}>
                    EFICIÊNCIA PROJETADA COM OMNICHAT
                  </span>
                  <h4 class="font-lato font-black text-lg text-zinc-900" id={`res-dim${index + 1}-efficiency-title`}>Carregando...</h4>
                  <p 
                    id={`res-dim${index + 1}-efficiency-desc`}
                    class={`text-xs text-zinc-850 leading-relaxed font-medium card-paragraph ${index === 0 ? "" : "hidden"}`}
                  >
                    Carregando...
                  </p>
                </div>
              </div>

            </div>
          </div>
        </div>
      );
    })}
  </div>

  <!-- RISK ALERT SECTION (Dynamic Warning Box matching APHO styles) -->
  <div id="res-risk-alert-box" class="hidden py-8 border-t border-[#FFD04D]/15 space-y-4 relative z-10 animate-fade-in">
    <div class="space-y-1">
      <h3 class="font-lato font-extrabold md:text-3xl text-[#FFD04D] text-5xl">Alerta de Risco Operacional:</h3>
      <p class="font-lato font-light md:text-2xl text-[#FFD04D]/80 text-4xl">Alta Autonomia com Baixa Governança</p>
    </div>
    <p class="font-lato font-light max-w-4xl tracking-wide text-lg normal-case text-left not-italic text-[#ffffff]">
      Sua operação possui um alto nível de autonomia e flexibilidade na tomada de decisões pela IA, porém as suas regras sistêmicas e políticas de governança estão baixas. Isso cria uma perigosa zona de vulnerabilidade jurídica e financeira para sua empresa, expondo o canal conversacional a possíveis alucinações comerciais, erros de precificação, vazamento de dados ou termos indevidos sem travas de controle.
    </p>
  </div>

  <!-- MERCADO E BENCHMARK SETORIAL (2-Column Typographic Layout matching Figma) -->
  <div class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-12 py-12 border-t border-[#FFD04D]/15 items-start relative z-10">
    <!-- Left Column: Title + Description -->
    <div class="md:col-span-6 space-y-6">
      <div class="space-y-0.5">
        <h3 class="font-lato font-black text-4xl md:text-5xl text-[#FFD04D] leading-none uppercase tracking-wide">
          mercado e
        </h3>
        <h3 class="font-lato font-black text-4xl md:text-5xl text-[#FFD04D] leading-none uppercase tracking-wide">
          benchmark
        </h3>
        <h3 class="font-lato font-black text-4xl md:text-5xl text-[#FFD04D] leading-none uppercase tracking-wide">
          setorial
        </h3>
      </div>
      <p id="res-market-facts-desc" class="text-zinc-400 text-sm font-lato font-light leading-relaxed max-w-lg lowercase">
        no varejo digital brasileiro, mais de 78% dos carrinhos são abandonados. marcas líderes de e-commerce que adotam agentes comerciais de ia com atribuição fechada alcançam uma conversão de vendas até 4.2x maior que canais tradicionais de e-mail e sms.
      </p>
    </div>

    <!-- Right Column: Big Statistic -->
    <div class="md:col-span-6 space-y-4 md:pt-2">
      <div id="res-market-stat-number" class="font-lato font-bold text-[7.5rem] md:text-[9.5rem] leading-[0.95] text-white tracking-tighter">
        4.2x
      </div>
      <p id="res-market-stat-label" class="text-zinc-400 text-sm font-lato font-light leading-relaxed max-w-sm lowercase">
        é o aumento de conversão de vendas que adota agentes comerciais para sua operação
      </p>
    </div>
  </div>

  <!-- Call To Action (Unlock Full Report) - Premium metallic dark gradient card matching Figma -->
  <div class="py-10 border-t border-[#FFD04D]/15 relative z-10 flex justify-center">
    <div class="relative w-full max-w-4xl bg-gradient-to-br from-[#12101a] via-[#161421] to-[#09070e]/95 border border-[#FFD04D]/25 rounded-[2rem] p-8 md:p-12 text-center space-y-6 overflow-hidden shadow-2xl backdrop-blur-md">
      <div class="absolute -top-32 -left-32 w-80 h-80 bg-purple-600/10 rounded-full blur-3xl pointer-events-none"></div>
      <div class="absolute -bottom-32 -right-32 w-80 h-80 bg-accent/10 rounded-full blur-3xl pointer-events-none"></div>
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-purple-900/10 via-transparent to-transparent pointer-events-none"></div>

      <div class="max-w-xl mx-auto space-y-5 relative z-10 flex flex-col items-center">
        <div class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-purple-500/10 border border-purple-500/20 text-[#FFD04D] mb-2 shadow-inner">
          <svg class="w-5 h-5 animate-pulse" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
          </svg>
        </div>
        <h3 class="font-lato font-black text-2xl md:text-3.5xl tracking-tight text-white leading-tight">Deseja liberar seu plano de ação detalhado?</h3>
        <p class="text-sm text-zinc-300 font-lato font-light leading-relaxed">
          Personalizamos um relatório estratégico corporativo completo em PDF e uma simulação guiada direto no seu WhatsApp comercial, baseando-se em cada uma das suas respostas.
        </p>
        <div class="pt-4 w-full sm:w-auto">
          <Button 
            id="btn-unlock-report"
            class="px-10 py-4.5 text-xs font-black uppercase tracking-[0.12em] flex items-center justify-center gap-3 mx-auto !rounded-full !bg-[#9400FF] hover:!bg-[#8100EB] shadow-lg shadow-purple-600/30 border border-purple-500/40 !text-white transition-all hover:scale-[1.03] active:scale-[0.99]"
          >
            Liberar Diagnóstico no WhatsApp
            <svg class="w-4.5 h-4.5 shrink-0" fill="currentColor" viewBox="0 0 24 24">
              <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.724-1.455L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.825 1.451 5.436 0 9.86-4.37 9.864-9.799.002-2.623-1.023-5.086-2.885-6.948C16.59 2.016 14.135 1 11.997 1 6.562 1 2.135 5.371 2.131 10.8c-.001 1.76.474 3.478 1.38 5.003L2.503 21.1l5.411-1.419c.11.06.222.114.333.165zM17.115 14c-.28-.14-1.655-.815-1.912-.91-.256-.092-.443-.14-.63.14-.187.28-.724.91-.887 1.095-.164.186-.328.21-.608.07-.28-.14-1.182-.435-2.251-1.39-.831-.742-1.393-1.658-1.556-1.938-.163-.28-.017-.431.122-.571.125-.125.28-.327.42-.49.14-.163.187-.28.28-.467.094-.187.047-.35-.024-.49-.07-.14-.63-1.517-.862-2.078-.227-.547-.457-.473-.63-.482-.163-.008-.35-.01-.537-.01-.187 0-.49.07-.747.35-.257.28-.981.958-.981 2.333 0 1.375.999 2.702 1.14 2.888.14.187 1.966 3.004 4.761 4.21.665.286 1.184.457 1.588.585.668.213 1.277.182 1.758.11.536-.08 1.655-.677 1.887-1.332.234-.655.234-1.215.164-1.332-.07-.116-.257-.186-.537-.326z"/>
            </svg>
          </Button>
        </div>
      </div>
    </div>
  </div>

</section>

<!-- Accordion Client Script -->
<script>
  function setupAccordion() {
    const items = document.querySelectorAll('.accordion-item');
    items.forEach(item => {
      const trigger = item.querySelector('.accordion-trigger');
      const content = item.querySelector('.accordion-content');
      const icon = item.querySelector('.accordion-icon');
      const index = item.getAttribute('data-index');
      const scoreCollapsed = document.getElementById(`res-dim${index}-score-collapsed`);

      if (!trigger) return;

      // Guard: ensure each trigger is wired with exactly one click handler
      if ((trigger as HTMLElement).dataset.accordionWired === '1') return;
      (trigger as HTMLElement).dataset.accordionWired = '1';

      trigger.addEventListener('click', () => {
        const isCurrentlyActive = item.classList.contains('active');

        // Close all other items
        items.forEach(otherItem => {
          if (otherItem !== item) {
            otherItem.classList.remove('active');
            otherItem.querySelector('.accordion-content')?.classList.add('hidden');
            
            const otherIndex = otherItem.getAttribute('data-index');
            const otherScoreCollapsed = document.getElementById(`res-dim${otherIndex}-score-collapsed`);
            if (otherScoreCollapsed) otherScoreCollapsed.style.display = 'inline';

            const otherIcon = otherItem.querySelector('.accordion-icon');
            if (otherIcon) {
              otherIcon.textContent = '+';
              otherIcon.className = "accordion-icon h-10 w-10 shrink-0 rounded-full bg-[#FFD04D] text-black flex items-center justify-center font-bold text-lg shadow-md transition-all";
            }

            // Close cards of other item
            const card1 = document.getElementById(`res-dim${otherIndex}-card1`);
            const card2 = document.getElementById(`res-dim${otherIndex}-card2`);
            const card3 = document.getElementById(`res-dim${otherIndex}-card3`);

            if (card1) {
              card1.className = "bg-white rounded-3xl p-5 shadow-md border border-zinc-100 min-h-[70px] text-black transition-all duration-300";
              card1.querySelector('.card-label')?.classList.add('hidden');
              card1.querySelector('.card-paragraph')?.classList.add('hidden');
            }
            if (card2) {
              card2.className = "bg-[#fffde6] rounded-3xl p-5 shadow-md min-h-[70px] text-black transition-all duration-300";
              card2.querySelector('.card-label')?.classList.add('hidden');
              card2.querySelector('.card-score-block')?.classList.add('hidden');
            }
            if (card3) {
              card3.className = "bg-[#FFD04D]/90 rounded-3xl p-5 shadow-md min-h-[70px] text-black transition-all duration-300";
              card3.querySelector('.card-label')?.classList.add('hidden');
              card3.querySelector('.card-paragraph')?.classList.add('hidden');
            }
          }
        });

        // Toggle current item
        const card1 = document.getElementById(`res-dim${index}-card1`);
        const card2 = document.getElementById(`res-dim${index}-card2`);
        const card3 = document.getElementById(`res-dim${index}-card3`);

        if (isCurrentlyActive) {
          item.classList.remove('active');
          content?.classList.add('hidden');
          if (scoreCollapsed) scoreCollapsed.style.display = 'inline';
          if (icon) {
            icon.textContent = '+';
            icon.className = "accordion-icon h-10 w-10 shrink-0 rounded-full bg-[#FFD04D] text-black flex items-center justify-center font-bold text-lg shadow-md transition-all";
          }

          if (card1) {
            card1.className = "bg-white rounded-3xl p-5 shadow-md border border-zinc-100 min-h-[70px] text-black transition-all duration-300";
            card1.querySelector('.card-label')?.classList.add('hidden');
            card1.querySelector('.card-paragraph')?.classList.add('hidden');
          }
          if (card2) {
            card2.className = "bg-[#fffde6] rounded-3xl p-5 shadow-md min-h-[70px] text-black transition-all duration-300";
            card2.querySelector('.card-label')?.classList.add('hidden');
            card2.querySelector('.card-score-block')?.classList.add('hidden');
          }
          if (card3) {
            card3.className = "bg-[#FFD04D]/90 rounded-3xl p-5 shadow-md min-h-[70px] text-black transition-all duration-300";
            card3.querySelector('.card-label')?.classList.add('hidden');
            card3.querySelector('.card-paragraph')?.classList.add('hidden');
          }
        } else {
          item.classList.add('active');
          content?.classList.remove('hidden');
          if (scoreCollapsed) scoreCollapsed.style.display = 'none';
          if (icon) {
            icon.textContent = '-';
            icon.className = "accordion-icon h-10 w-10 shrink-0 rounded-full bg-white text-black flex items-center justify-center font-bold text-xl shadow-md transition-all";
          }

          if (card1) {
            card1.className = "bg-white rounded-3xl p-6 shadow-xl border border-zinc-100 min-h-[180px] text-black transition-all duration-300";
            card1.querySelector('.card-label')?.classList.remove('hidden');
            card1.querySelector('.card-paragraph')?.classList.remove('hidden');
          }
          if (card2) {
            const bgClass = card2.getAttribute('data-bg-class') || 'bg-[#9df09e]';
            card2.className = `${bgClass} rounded-3xl p-6 shadow-xl min-h-[180px] text-black transition-all duration-300`;
            card2.querySelector('.card-label')?.classList.remove('hidden');
            card2.querySelector('.card-score-block')?.classList.remove('hidden');
          }
          if (card3) {
            card3.className = "bg-[#FFD04D] rounded-3xl p-6 shadow-xl min-h-[180px] text-black transition-all duration-300";
            card3.querySelector('.card-label')?.classList.remove('hidden');
            card3.querySelector('.card-paragraph')?.classList.remove('hidden');
          }
        }
      });
    });
  }

  // Single idempotent init (handler guard prevents any double-binding)
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupAccordion);
  } else {
    setupAccordion();
  }
</script>


---
import Gauge from './ui/Gauge.astro';
import Progress from './ui/Progress.astro';
import Button from './ui/Button.astro';

const dimensions = [
  {
    id: 'revenue',
    name: '1. Estratégia e Canal',
    description: 'Papel da IA no funil comercial e metas de receita explícitas.'
  },
  {
    id: 'data',
    name: '2. Dados e Atribuição',
    description: 'Rastreabilidade de mídias pagas (Meta Ads) e dashboards de receita.'
  },
  {
    id: 'autonomy',
    name: '3. Operação e Performance',
    description: 'Tempo de resposta imediato, FAQs dinâmicos e objeções fluidas.'
  },
  {
    id: 'human',
    name: '4. Governança e Segurança',
    description: 'Travas rígidas de preços/descontos e handoffs estruturados de IA-humano.'
  },
  {
    id: 'governance',
    name: '5. Ownership e Organização',
    description: 'Líder dedicado do canal conversacional e cadência semanal de testes e dados.'
  }
] as const;

const comparisonMetrics = [
  {
    label: "Posicionamento e Papel Comercial",
    current: "Apenas FAQ / suporte reativo",
    ideal: "Jornada de Vendas Ativa e Autônoma"
  },
  {
    label: "Atribuição de Mídia Paga (Meta Ads)",
    current: "Mídia sem Atribuição ou Manual",
    ideal: "Integração API de Conversões 100%"
  },
  {
    label: "Governança Comercial e Handoff",
    current: "Fila Cega, Risco de Alucinação",
    ideal: "Handoff Inteligente com Travas Rígidas"
  }
];
---
<!-- ==================== TELA 3: RESULTADOS (Glassmorphism Edit) ==================== -->
<section id="stage-3" class="hidden space-y-12 transition-all duration-500 ease-in-out animate-fade-in">
  <!-- Title Header -->
  <div class="text-center space-y-4">
    <div class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-xs font-semibold tracking-wide uppercase font-lato">
      <span class="h-2 w-2 rounded-full bg-emerald-500 shadow-md shadow-emerald-500/50"></span>
      Painel Executivo Concluído
    </div>
    <h1 class="font-lato text-3xl md:text-5xl font-extrabold tracking-tight text-[#FFD04D] leading-tight">
      Diagnóstico de Maturidade de IA Comercial
    </h1>
    <p class="text-muted text-sm md:text-base max-w-2xl mx-auto font-lato">
      Relatório estruturado de prontidão para habilitar agentes inteligentes como canal de vendas ativo de alta performance no WhatsApp.
    </p>
  </div>

  <!-- BLOCK 1 — Resumo Executivo (Tilted-highlight glassmorphic box) -->
  <div class="relative bg-gradient-to-r from-purple-950/20 to-[#110f17]/40 backdrop-blur-xl border border-white/[0.06] rounded-[2rem] p-6 md:p-8 space-y-4 overflow-hidden shadow-2xl">
    <!-- Purple glow background -->
    <div class="absolute -top-24 -left-24 w-60 h-60 bg-purple-600/15 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute top-0 left-0 w-[5px] h-full bg-gradient-to-b from-purple-600 to-accent"></div>
    
    <div class="pl-3 md:pl-4 space-y-2 relative z-10">
      <span class="text-xs font-bold text-accent uppercase tracking-widest font-lato">Bloco 1 — Resumo Executivo</span>
      <h3 class="font-lato font-black text-2xl md:text-3xl text-foreground leading-tight" id="res-maturity-stage-name">
        --
      </h3>
      <p class="text-sm md:text-base text-muted leading-relaxed font-lato font-medium" id="res-maturity-description">
        Carregando análise personalizada sobre a maturidade comercial da sua operação...
      </p>
    </div>
  </div>

  <!-- BLOCK 2 — Scores & Dimensões (Scores & Dimension Breakdown) -->
  <div class="space-y-6">
    <div class="border-b border-white/[0.06] pb-3">
      <h3 class="font-lato font-bold text-xl text-foreground">Bloco 2 — Scores & Dimensões de Revenue AI</h3>
      <p class="text-xs text-muted font-lato">Abaixo estão as pontuações individuais para cada um dos pilares de prontidão comercial, com os pontos de maior urgência destacados.</p>
    </div>

    <div class="grid md:grid-cols-12 gap-6">
      <!-- Large Gauge (Left) - Glassmorphic widget with gradient matching Image 1 -->
      <div class="md:col-span-5 bg-[#110f17]/60 backdrop-blur-xl border border-white/[0.06] rounded-[2rem] p-6 md:p-8 flex flex-col items-center justify-center text-center relative overflow-hidden min-h-[320px] shadow-xl">
        <div class="absolute -top-32 -left-32 w-64 h-64 bg-purple-600/10 rounded-full blur-3xl pointer-events-none"></div>
        <span class="text-xs font-bold uppercase tracking-wider text-muted mb-6 font-lato">Maturidade Geral</span>
        
        <!-- Glowing Gauge shadow -->
        <div class="relative flex items-center justify-center">
          <div class="absolute inset-0 bg-accent/5 rounded-full blur-xl scale-75"></div>
          <Gauge idCircle="res-gauge-circle" idScore="res-overall-score" idLabel="res-maturity-label-gauge" />
        </div>
        
        <p class="text-xs text-muted max-w-xs mt-6 leading-relaxed font-lato font-medium">
          Nível de preparação operacional unificada do seu negócio.
        </p>
      </div>

      <!-- 5 Dimension Scores Progress Bars (Right) - Stylish Glass list with glow highlights -->
      <div class="md:col-span-7 flex flex-col gap-4">
        <div class="grid gap-4">
          {dimensions.map((dim, index) => (
            <div 
              id={`res-dim${index + 1}-container`} 
              class="space-y-3 p-4.5 rounded-2xl border border-white/[0.06] bg-[#110f17]/30 hover:bg-[#110f17]/50 backdrop-blur-md transition-all duration-300 relative overflow-hidden group shadow-md"
            >
              <!-- Horizontal light border inside -->
              <div class="absolute inset-x-0 top-0 h-[1px] bg-gradient-to-r from-transparent via-white/[0.03] to-transparent"></div>
              
              <div class="flex justify-between items-center relative z-10">
                <span class="text-xs font-bold text-muted uppercase tracking-wider font-lato block group-hover:text-foreground transition-colors">{dim.name}</span>
                <div class="flex items-center gap-2.5">
                  <span id={`res-dim${index + 1}-warning`} class="hidden text-amber-500 text-[10px] font-extrabold flex items-center gap-1 uppercase tracking-widest font-lato px-2 py-0.5 rounded bg-amber-500/10 border border-amber-500/20">
                    ⚠️ Gargalo
                  </span>
                  <span class="font-extrabold font-mono text-sm text-accent" id={`res-dim${index + 1}-score`}>0%</span>
                </div>
              </div>
              
              <div class="relative">
                <div class="absolute inset-0 bg-accent/5 blur-[4px] rounded-full"></div>
                <Progress id={`res-dim${index + 1}-bar`} height="sm" value="0%" class="relative z-10 !bg-white/5" />
              </div>
              
              <p class="text-[11px] text-muted/80 leading-snug font-lato font-medium relative z-10">{dim.description}</p>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Alerta de Risco Operacional (Alta Autonomia com Baixa Governança) -->
    <div id="res-risk-alert-box" class="hidden bg-red-950/20 border border-red-500/20 rounded-[2rem] p-6 md:p-8 space-y-4 animate-pulse shadow-lg shadow-red-950/10">
      <div class="flex items-start gap-4">
        <div class="h-11 w-11 shrink-0 rounded-xl bg-red-500/10 border border-red-500/20 text-red-400 flex items-center justify-center">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
          </svg>
        </div>
        <div class="space-y-2">
          <h4 class="font-lato font-extrabold text-lg text-red-400">Alerta de Risco Operacional: Alta Autonomia com Baixa Governança</h4>
          <p class="text-sm text-foreground/80 leading-relaxed font-lato font-medium">
            Sua operação possui um alto nível de autonomia e flexibilidade na tomada de decisões pela IA, porém as suas regras sistêmicas e políticas de governança estão baixas. Isso cria uma perigosa zona de vulnerabilidade jurídica e financeira para sua empresa, expondo o canal conversacional a possíveis alucinações comerciais, erros de precificação, vazamento de dados ou termos indevidos sem travas de controle.
          </p>
        </div>
      </div>
    </div>
  </div>

  <!-- BLOCK 3 — Principais Gargalos (Primary Bottlenecks) -->
  <div class="bg-[#110f17]/60 backdrop-blur-xl border border-white/[0.06] rounded-[2rem] p-6 md:p-8 space-y-5 shadow-xl relative overflow-hidden">
    <div class="absolute -bottom-24 -left-24 w-60 h-60 bg-amber-500/[0.02] rounded-full blur-3xl pointer-events-none"></div>
    <div class="flex items-center gap-3.5 relative z-10">
      <div class="h-11 w-11 shrink-0 rounded-xl bg-amber-500/10 border border-amber-500/20 text-amber-500 flex items-center justify-center">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
        </svg>
      </div>
      <div>
        <h3 class="font-lato font-extrabold text-xl text-foreground">Bloco 3 — Principais Gargalos Estratégicos</h3>
        <p class="text-xs text-muted font-lato">Obstáculos operacionais inferidos a partir das suas respostas e nível de prontidão.</p>
      </div>
    </div>
    <ul id="inferred-bottlenecks" class="grid sm:grid-cols-2 gap-4 pt-2 relative z-10">
      <!-- Dynamically filled list -->
    </ul>
  </div>

  <!-- BLOCK 4 — Mercado e Benchmark Setorial (Market & Sector Benchmark) -->
  <div class="bg-[#110f17]/60 backdrop-blur-xl border border-white/[0.06] rounded-[2rem] p-6 md:p-8 space-y-6 shadow-xl relative overflow-hidden">
    <div class="absolute -top-32 -right-32 w-64 h-64 bg-purple-500/[0.03] rounded-full blur-3xl pointer-events-none"></div>
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-b border-white/[0.06] pb-4 relative z-10">
      <div class="space-y-1">
        <h3 class="font-lato font-bold text-xl text-foreground">Bloco 4 — Mercado e Benchmark Setorial</h3>
        <p class="text-xs text-muted font-lato">Adote padrões de maturidade específicos para impulsionar seu segmento.</p>
      </div>
      <div class="shrink-0 space-y-1">
        <label for="select-sector" class="text-[9px] font-extrabold uppercase tracking-widest text-muted block font-lato">Setor de Atuação</label>
        <select 
          id="select-sector" 
          class="px-3.5 py-2.5 rounded-xl border border-white/10 bg-[#14121b] text-foreground focus:border-purple-500 focus:ring-1 focus:ring-purple-500 outline-none text-xs font-bold cursor-pointer font-lato transition-all"
        >
          <option value="Varejo & E-commerce" selected>Varejo & E-commerce</option>
          <option value="Saúde & Clínicas">Saúde & Clínicas</option>
          <option value="Serviços Financeiros">Serviços Financeiros</option>
          <option value="Tecnologia & SaaS">Tecnologia & SaaS</option>
          <option value="Logística & Distribuição">Logística & Distribuição</option>
          <option value="Outros">Outros</option>
        </select>
      </div>
    </div>
    <div id="market-benchmark" class="text-sm text-foreground/80 leading-relaxed font-lato font-medium bg-purple-950/15 p-5 rounded-2xl border border-purple-500/20 relative z-10 shadow-inner">
      <!-- Dynamically filled paragraph -->
    </div>
  </div>

  <!-- BLOCK 5 — Eficiência Projetada (Projected Efficiency) -->
  <div class="bg-gradient-to-br from-purple-950/10 to-accent/[0.01] border border-purple-500/20 rounded-[2rem] p-6 md:p-8 space-y-5 shadow-xl relative overflow-hidden">
    <div class="absolute top-0 right-0 w-32 h-32 bg-purple-600/[0.05] rounded-full blur-2xl pointer-events-none"></div>
    <div class="flex items-center gap-3.5 relative z-10">
      <div class="h-11 w-11 shrink-0 rounded-xl bg-purple-500/10 border border-purple-500/20 text-purple-400 flex items-center justify-center">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 10V3L4 14h7v7l9-11h-7z" />
        </svg>
      </div>
      <div>
        <h3 class="font-lato font-extrabold text-xl text-foreground">Bloco 5 — Eficiência Projetada com OmniChat + Parceiro</h3>
        <p class="text-xs text-muted font-lato">Estimativa consultiva de performance ao estruturar canais inteligentes integrados.</p>
      </div>
    </div>
    <div id="projected-efficiency" class="grid sm:grid-cols-2 gap-4 pt-2 relative z-10">
      <!-- Dynamically filled grid items -->
    </div>
  </div>

  <!-- BLOCK 6 — Plano de Ação (90-Day Action Plan) -->
  <div class="bg-[#110f17]/60 backdrop-blur-xl border border-white/[0.06] rounded-[2rem] p-6 md:p-8 space-y-5 shadow-xl relative overflow-hidden">
    <div class="absolute -top-32 -left-32 w-64 h-64 bg-emerald-500/[0.02] rounded-full blur-3xl pointer-events-none"></div>
    <div class="flex items-center gap-3.5 border-b border-white/[0.06] pb-4 relative z-10">
      <div class="h-11 w-11 shrink-0 rounded-xl bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 flex items-center justify-center">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
        </svg>
      </div>
      <div>
        <h3 class="font-lato font-extrabold text-xl text-foreground">Bloco 6 — Plano de Ação Estratégico (90 Dias)</h3>
        <p class="text-xs text-muted font-lato">Ações prioritárias organizadas cronologicamente para sua liderança e equipe.</p>
      </div>
    </div>
    <div id="action-plan" class="space-y-4 pt-2 relative z-10">
      <!-- Dynamically filled list -->
    </div>
  </div>

  <!-- BLOCK 7 — Case do Setor (Industry Success Case) -->
  <div class="bg-[#110f17]/60 backdrop-blur-xl border border-white/[0.06] rounded-[2rem] p-6 md:p-8 space-y-6 relative overflow-hidden shadow-2xl">
    <div class="absolute -bottom-32 -right-32 w-80 h-80 bg-purple-500/[0.05] rounded-full blur-3xl pointer-events-none"></div>
    <div class="flex items-center gap-3 relative z-10">
      <span class="px-3 py-1 text-[10px] font-extrabold uppercase tracking-widest bg-accent/10 text-accent rounded-full border border-accent/20 font-lato">Bloco 7 — Case de Sucesso Recomendado</span>
    </div>
    
    <div class="space-y-4 relative z-10">
      <div class="space-y-1.5">
        <div class="flex items-baseline gap-2.5 flex-wrap">
          <h4 class="font-lato font-black text-2xl md:text-3xl text-foreground leading-tight" id="success-case-brand">--</h4>
          <span class="text-[10px] text-muted font-bold uppercase tracking-widest font-lato px-2 py-0.5 rounded bg-white/5 border border-white/10" id="success-case-segment">--</span>
        </div>
        <p class="text-base md:text-lg font-extrabold text-emerald-400 font-lato leading-tight" id="success-case-result">--</p>
      </div>
      
      <div class="grid sm:grid-cols-3 gap-6 pt-5 border-t border-white/[0.06] font-normal font-lato">
        <div class="space-y-2">
          <span class="text-xs font-bold uppercase tracking-wider text-muted block">Problema Enfrentado</span>
          <p class="text-xs text-foreground/80 leading-relaxed font-medium" id="success-case-problem">--</p>
        </div>
        <div class="space-y-2">
          <span class="text-xs font-bold uppercase tracking-wider text-muted block">Abordagem Adotada</span>
          <p class="text-xs text-foreground/80 leading-relaxed font-medium" id="success-case-approach">--</p>
        </div>
        <div class="space-y-2">
          <span class="text-xs font-bold uppercase tracking-wider text-accent block">Takeaway Estratégico</span>
          <p class="text-xs text-accent/90 leading-relaxed font-semibold italic shadow-sm" id="success-case-takeaway">--</p>
        </div>
      </div>
    </div>
  </div>

  <!-- COMPARISON TABLE (High-Contrast comparison) -->
  <div class="bg-[#110f17]/60 backdrop-blur-xl border border-white/[0.06] rounded-[2rem] p-6 md:p-8 space-y-6 shadow-xl relative overflow-hidden">
    <div class="border-b border-white/[0.06] pb-3">
      <h3 class="font-lato font-bold text-xl text-foreground">Como o seu Canal Conversacional vai evoluir</h3>
      <p class="text-xs text-muted font-lato">Mapeamento da transformação operacional de canais passivos para canais de receita.</p>
    </div>
    
    <div class="grid gap-5 pt-2">
      {comparisonMetrics.map(m => (
        <div class="grid md:grid-cols-2 gap-4 p-4.5 rounded-xl border border-white/[0.04] bg-white/[0.01]">
          <div>
            <span class="text-[10px] font-extrabold uppercase tracking-widest text-red-400 block mb-2 font-lato">⚠️ Operação Atual (Como está)</span>
            <p class="text-sm font-lato font-medium text-muted">{m.current}</p>
          </div>
          <div class="border-t md:border-t-0 md:border-l border-white/[0.06] pt-3 md:pt-0 md:pl-5">
            <span class="text-[10px] font-extrabold uppercase tracking-widest text-emerald-400 block mb-2 font-lato">🎯 Com Revenue AI (Como deve ser)</span>
            <p class="text-sm font-lato font-bold text-foreground">{m.ideal}</p>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Call To Action (Unlock Full Report) - Smooth metallic dark gradient card -->
  <div class="relative bg-gradient-to-br from-[#12101a] via-[#161421] to-[#09070e] border border-purple-500/30 rounded-[2rem] p-8 text-center space-y-6 overflow-hidden shadow-2xl">
    <div class="absolute -top-32 -left-32 w-80 h-80 bg-purple-600/10 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute -bottom-32 -right-32 w-80 h-80 bg-accent/10 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-purple-900/10 via-transparent to-transparent pointer-events-none"></div>

    <div class="max-w-xl mx-auto space-y-4 relative z-10">
      <h3 class="font-lato font-black text-2xl md:text-3xl tracking-tight text-white">Deseja liberar seu plano de ação detalhado?</h3>
      <p class="text-sm text-zinc-300 font-lato font-medium leading-relaxed">
        Personalizamos um relatório estratégico corporativo completo em PDF e uma simulação guiada direto no seu WhatsApp comercial, baseando-se em cada uma das suas respostas.
      </p>
      <div class="pt-2">
        <Button 
          id="btn-unlock-report"
          class="px-8 py-4.5 text-sm font-extrabold uppercase tracking-[0.08em] flex items-center justify-center gap-2.5 mx-auto !rounded-xl !bg-purple-600 hover:!bg-purple-500 shadow-lg shadow-purple-600/25 border-0 !text-white"
        >
          Liberar Diagnóstico no WhatsApp
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
        </Button>
      </div>
    </div>
  </div>
</section>

---
import '../styles/global.css';
import GoogleTagManager from '../components/GoogleTagManager.astro';
import GoogleTagManagerNoScript from '../components/GoogleTagManagerNoScript.astro';
import { SEO } from 'astro-seo';

interface Props {
  title?: string;
}

const { title = 'Diagnóstico de IA Comercial • OmniChat' } = Astro.props;
const description = 'Avalie a maturidade de IA comercial da sua operação com o diagnóstico do OmniChat. Otimize suas vendas, autonomia e atribuição de anúncios no WhatsApp.';
const canonicalURL = 'https://omni.chat/';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- SEO Meta Tags using astro-seo -->
    <SEO
      title={title}
      description={description}
      canonical={canonicalURL}
      openGraph={{
        basic: {
          title: title,
          type: 'website',
          image: 'https://omni.chat/og/opengraph.png',
        },
        image: {
          alt: 'Maturidade de IA Comercial OmniChat',
        }
      }}
      extend={{
        link: [
          { rel: 'icon', type: 'image/svg+xml', href: '/favicon.svg' },
          { rel: 'shortcut icon', href: '/favicon/favicon.ico' },
          { rel: 'icon', type: 'image/png', sizes: '32x32', href: '/favicon/favicon-32x32.png' },
          { rel: 'icon', type: 'image/png', sizes: '16x16', href: '/favicon/favicon-16x16.png' },
          { rel: 'apple-touch-icon', sizes: '180x180', href: '/favicon/apple-touch-icon.png' },
          { rel: 'manifest', href: '/favicon/site.webmanifest' }
        ]
      }}
    />

    <!-- GTM Head script -->
    <GoogleTagManager />
  </head>
  <body class="bg-background text-foreground font-body antialiased">
    <!-- GTM NoScript fallback -->
    <GoogleTagManagerNoScript />
    <slot />
  </body>
</html>
